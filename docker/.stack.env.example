# Copy this file to docker/.stack.env and replace placeholders before running the stack.
# Format matters: use plain KEY=value lines only. Do not prefix entries with `export`.
# Values here are loaded by Docker Compose and passed into the containers that need them.

# -------------------------
# Frontend build-time config
# -------------------------
# Browser-visible API base URL embedded into the Vite build.
VITE_API_URL=http://localhost:8000
# Google OAuth client ID exposed to the frontend.
VITE_GOOGLE_CLIENT_ID=
# Stripe publishable key exposed to the frontend.
VITE_STRIPE_PUBLISHABLE_KEY=
# Optional frontend Sentry DSN.
VITE_SENTRY_DSN=

# -------------------------
# Backend auth and session config
# -------------------------
# Google model features that use direct API keys read this.
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/oauth/google/callback
# Session cookie signing key for OAuth/session flows.
SESSION_SECRET_KEY=
# JWT access token lifetime in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# -------------------------
# Composio integration
# -------------------------
COMPOSIO_API_KEY=
COMPOSIO_ENCRYPTION_KEY=
COMPOSIO_REDIRECT_URI=http://localhost:1420/auth/oauth/composio/callback

# -------------------------
# Billing and domain automation
# -------------------------
# Cloudflare domain automation. Leave blank unless you use custom subdomains.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_BASE_DOMAIN=

# Stripe billing. Leave blank if billing is disabled in your stack.
STRIPE_SECRET_KEY=
STRIPE_PRICE_PLUS_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PLUS_ANNUALLY=
STRIPE_PRICE_PRO_ANNUALLY=
STRIPE_WEBHOOK_SECRET=

# -------------------------
# Admin model seed config
# -------------------------
# Single-line JSON blob used to seed admin LLM settings at startup.
LLM_CONFIGS=

# -------------------------
# Backend storage config
# -------------------------
# Host path mounted into containers for Google client libraries.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/ii-agent-service-account.json
STORAGE_PROVIDER=gcs

# Slide assets storage
STORAGE_SLIDE_ASSETS_PROJECT_ID=
STORAGE_SLIDE_ASSETS_BUCKET_NAME=

# File upload storage
STORAGE_FILE_UPLOAD_PROJECT_ID=
STORAGE_FILE_UPLOAD_BUCKET_NAME=

# Avatar storage
STORAGE_AVATAR_PROJECT_ID=
STORAGE_AVATAR_BUCKET_NAME=

# Media storage
STORAGE_MEDIA_PROJECT_ID=
STORAGE_MEDIA_BUCKET_NAME=

# Optional public custom domain used for generated file URLs.
STORAGE_CUSTOM_DOMAIN=

# -------------------------
# Sandbox runtime config
# -------------------------
SANDBOX_PROVIDER=e2b
# Backend and Celery runtime use the SANDBOX_E2B_* names.
SANDBOX_E2B_API_KEY=
SANDBOX_E2B_TEMPLATE_ID=base
SANDBOX_TIME_TIL_CLEAN_UP=1800
# Some E2B tool paths still read the plain E2B_API_KEY name directly.
E2B_API_KEY=

# -------------------------
# Core infrastructure
# -------------------------
POSTGRES_USER=iiagent
POSTGRES_PASSWORD=iiagent
POSTGRES_DB=iiagentdev
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://iiagent:iiagent@postgres:5432/iiagentdev
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=1420
CELERY_LOGLEVEL=info
CELERY_QUEUES=default,high_priority,low_priority
CELERY_WORKER_CONCURRENCY=4
